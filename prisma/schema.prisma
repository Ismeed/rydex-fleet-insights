datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_OWNER
  OPERATIONS_MANAGER
}

enum VehicleStatus {
  AVAILABLE
  ON_ROAD
  MAINTENANCE
  INACTIVE
  RETIRED
}

enum ShiftStatus {
  ACTIVE
  ENDED
  LOW_PERF
  FLAGGED
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
  SUSPENDED
}

enum MaintenanceType {
  GENERAL_SERVICE
  OIL_CHANGE
  BRAKE_REPAIR
  TYRE_REPLACEMENT
  ENGINE_REPAIR
  CNG_INSPECTION
  ELECTRICAL_REPAIR
}

model Company {
  id           String    @id @default(uuid())
  name         String
  logo         String?
  phone        String
  email        String?
  address      String?
  country      String    @default("Nigeria")
  state        String?
  fleetType    String    @default("General") // "CNG", "EV", "Tricycle", "Bus", "Motorcycle", "Logistics", etc.
  subscription String    @default("TRIAL") // TRIAL, BASIC, PREMIUM, ENTERPRISE
  status       String    @default("ACTIVE") // ACTIVE, SUSPENDED, PENDING
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users        User[]
  drivers      Driver[]
  vehicles     Vehicle[]
  shifts       Shift[]
  contracts    HirePurchaseContract[]
  maintenances MaintenanceJob[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String?  @unique
  status    String   @default("active") // "active", "suspended"
  password  String
  role      UserRole @default(COMPANY_OWNER)
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Driver {
  id             String   @id @default(uuid())
  name           String
  phone          String   @unique
  address        String
  guarantorName  String
  guarantorPhone String
  status         String   @default("active") // "active", "suspended", "off-duty"
  passport       String?
  emergencyContact String?
  nextOfKin      String?
  licenseNumber  String?
  nationalId     String?
  employmentDate DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedVehicle Vehicle?
  shifts          Shift[]
  contract        HirePurchaseContract?
}

model Vehicle {
  id                 String        @id @default(uuid())
  vehicleNumber      String        @unique
  registrationNumber String?       @unique
  engineNumber       String?       @unique
  chassisNumber      String?       @unique
  vehicleType        String        @default("Keke Napep")
  fuelType           String        @default("CNG") // CNG, EV, Petrol, Diesel
  plateNumber        String        @unique
  status             VehicleStatus @default(AVAILABLE)
  purchaseDate       DateTime?
  purchasePrice      Float?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  companyId          String
  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedDriverId   String?       @unique
  assignedDriver     Driver?       @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)

  shifts             Shift[]
  contract           HirePurchaseContract?
  maintenances       MaintenanceJob[]
}

model Shift {
  id              String      @id @default(uuid())
  startTime       DateTime    @default(now())
  endTime         DateTime?
  startOdometer   Float
  endOdometer     Float?
  revenue         Float?      @default(0)
  hoursWorked     Int?
  minutesWorked   Int?
  distanceCovered Float?
  revenuePerHour  Float?
  revenuePerKm    Float?
  status          ShiftStatus @default(ACTIVE)
  amountExpected  Float       @default(0)
  amountReceived  Float       @default(0)
  outstandingBalance Float    @default(0)
  remarks         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  vehicleId       String
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  driverId        String
  driver          Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model HirePurchaseContract {
  id               String         @id @default(uuid())
  startDate        DateTime       @default(now())
  targetAmount     Float
  dailyTarget      Float
  totalPaid        Float          @default(0)
  remainingBalance Float
  status           ContractStatus @default(ACTIVE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  companyId        String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  vehicleId        String         @unique
  vehicle          Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  driverId         String         @unique
  driver           Driver         @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model MaintenanceJob {
  id        String          @id @default(uuid())
  type      MaintenanceType
  workshop  String
  cost      Float
  date      DateTime        @default(now())
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  companyId String
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  vehicleId String
  vehicle   Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}
